---
import '../styles/global.css';
import { createMapTilerProvider } from '../lib/MapTilerProvider';

const provider = createMapTilerProvider();
const styleURL = provider.getStyleURL();
const attribution = provider.attribution;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Mapa del estacionamiento medido en Argentina. Consultá dónde y cuándo rige, ciudad por ciudad."
    />
    <title>DondeEstacionarGratis — Mapa del estacionamiento medido en Argentina</title>
  </head>
  <body class="m-0 h-screen w-screen overflow-hidden bg-gray-900">
    <div
      id="map"
      class="h-full w-full"
      data-style-url={styleURL}
      data-attribution={attribution}
    ></div>

    <script>
      import maplibregl from 'maplibre-gl';
      import 'maplibre-gl/dist/maplibre-gl.css';

      const mapEl = document.getElementById('map')!;
      const styleURL = mapEl.dataset.styleUrl!;
      const attribution = mapEl.dataset.attribution!;

      const map = new maplibregl.Map({
        container: 'map',
        style: styleURL,
        center: [-63, -38],
        zoom: 4,
        attributionControl: false,
      });

      map.addControl(
        new maplibregl.AttributionControl({
          customAttribution: attribution,
          compact: false,
        }),
      );

      map.addControl(new maplibregl.NavigationControl(), 'top-right');
    </script>
  </body>
</html>
